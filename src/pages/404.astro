---
import BaseLayout from '@/app/layouts/BaseLayout.astro';
---

<BaseLayout title="404">
  <div class="max-w-[800px] mx-auto flex flex-col items-center justify-center py-24 text-center">
    <h1 class="font-display text-6xl font-semibold text-[var(--color-text-primary)] mb-4">
      404
    </h1>
    <p class="font-ui text-lg text-[var(--color-text-secondary)] mb-8">
      페이지를 찾을 수 없습니다.
    </p>
    <a
      href="/"
      class="font-ui text-sm px-6 py-3 rounded-[5px] border border-[var(--color-divider)] text-[var(--color-text-primary)] no-underline hover:bg-[var(--color-action-hover)] transition-colors"
    >
      홈으로 돌아가기
    </a>
  </div>
</BaseLayout>
