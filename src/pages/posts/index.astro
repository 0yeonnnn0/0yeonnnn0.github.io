---
import BaseLayout from '@/app/layouts/BaseLayout.astro';
import PostListItem from '@/widgets/post-list/PostListItem.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '@/data/categories';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Posts" description="전체 글 목록">
  <div class="max-w-[800px] mx-auto">
    <h1 class="font-display text-[clamp(2rem,3.5vw,2.5rem)] font-semibold leading-[1.2] tracking-[-0.012em] mb-8">
      Posts
    </h1>

    {posts.length === 0 ? (
      <p class="font-ui text-[var(--color-text-secondary)]">아직 작성된 글이 없습니다.</p>
    ) : (
      <div class="flex flex-col">
        {posts.map((post) => (
          <div class="border-t border-[var(--color-divider)] first:border-t-0">
            <PostListItem
              id={post.id}
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              category={post.data.category}
              tags={post.data.tags}
              thumbnail={post.data.thumbnail}
            />
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
