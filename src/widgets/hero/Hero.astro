---
import { SITE } from '@/shared/config/site';
---

<section class="relative flex flex-col items-center overflow-hidden py-5 px-2 sm:py-6 sm:px-0 pb-8 sm:pb-9">
  <!-- Grid background pattern -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="
      background-image:
        repeating-linear-gradient(to right, #2C2B28 0, #2C2B28 1px, transparent 1px, transparent 28px),
        repeating-linear-gradient(to bottom, #2C2B28 0, #2C2B28 1px, transparent 1px, transparent 28px);
      opacity: 0.09;
      mask-image: radial-gradient(
        ellipse 68% 56% at 50% 45%,
        rgba(0,0,0,0.96) 0%, rgba(0,0,0,0.72) 40%,
        rgba(0,0,0,0.28) 66%, rgba(0,0,0,0) 100%
      );
      -webkit-mask-image: radial-gradient(
        ellipse 68% 56% at 50% 45%,
        rgba(0,0,0,0.96) 0%, rgba(0,0,0,0.72) 40%,
        rgba(0,0,0,0.28) 66%, rgba(0,0,0,0) 100%
      );
    "
  ></div>

  <!-- Caption -->
  <p
    class="font-ui text-[clamp(0.74rem,0.95vw,0.82rem)] font-normal leading-relaxed tracking-[0.06em] uppercase opacity-72 text-[var(--color-text-secondary)] mb-4"
  >
    Personal Blog
  </p>

  <!-- Title -->
  <h1
    class="font-display text-[clamp(2.429rem,4.2vw,2.95rem)] font-semibold leading-[1.14] tracking-[-0.012em] text-center text-[var(--color-text-primary)]"
  >
    {SITE.title}
  </h1>

  <!-- Subtitle -->
  <p
    class="font-body text-[clamp(1rem,1.28vw,1.08rem)] font-normal leading-[1.7] tracking-[-0.004em] text-center text-[var(--color-text-secondary)] mt-3 max-w-md"
  >
    {SITE.description}
  </p>
</section>
