---
import { getCollection } from 'astro:content';
import { STEADY_SELLERS } from '@/data/steady-sellers';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const steadyPosts = STEADY_SELLERS
  .slice(0, 10)
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean);
---

{steadyPosts.length > 0 && (
  <section>
    <h2 class="font-body text-[1.5rem] font-bold leading-[1.6] mb-6">
      Steady Sellers
    </h2>
    <ol class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-0">
      {steadyPosts.map((post, i) => (
        <li>
          <a
            href={`/posts/${post!.id}/`}
            class="flex items-center gap-8 px-5 py-5 rounded-[5px] no-underline transition-colors duration-200 ease-in-out hover:bg-[rgba(0,0,0,0.03)]"
          >
            <span class="font-body text-3xl font-light leading-none text-[#e0e0e0] w-10 shrink-0 text-center">
              {i + 1}
            </span>
            <div class="flex flex-col gap-1 min-w-0">
              <span class="font-body text-[1.0rem] font-bold leading-[1.4] text-[var(--color-text-primary)] truncate">
                {post!.data.title}
              </span>
              <span class="font-ui text-[0.9rem] leading-[1.3] text-[var(--color-text-secondary)]">
                {post!.data.category}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </section>
)}
